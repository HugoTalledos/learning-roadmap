---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/blog/TableOfContents.astro';
import ProjectTimeline from '../components/project/ProjectTimeline.astro';
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import { formatDate } from '../utils/seo';
import { getEntrySlug } from '../utils/projects';

interface Props {
  entry: CollectionEntry<'entries'>;
  headings: MarkdownHeading[];
  readingTime: number;
  projectTitle: string;
  projectSlug: string;
  allEntries: CollectionEntry<'entries'>[];
  prev?: CollectionEntry<'entries'>;
  next?: CollectionEntry<'entries'>;
}

const { entry, headings, readingTime, projectTitle, projectSlug, allEntries, prev, next } =
  Astro.props;
const { title, date, category, tags } = entry.data;
const currentSlug = getEntrySlug(entry);
---

<BaseLayout
  title={title}
  description={`${category ?? 'Entrada'} — ${projectTitle}`}
  type="article"
  publishedAt={date}
  tags={tags}
>
  <div class="mx-auto max-w-5xl px-4 py-12">
    <!-- Breadcrumb -->
    <nav
      class="mb-8 flex items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400"
      aria-label="Breadcrumb"
    >
      <a href="/projects" class="transition-colors hover:text-gray-900 dark:hover:text-gray-100"
        >Proyectos</a
      >
      <span>/</span>
      <a
        href={`/projects/${projectSlug}`}
        class="transition-colors hover:text-gray-900 dark:hover:text-gray-100">{projectTitle}</a
      >
      <span>/</span>
      <span class="text-gray-900 dark:text-gray-100">{title}</span>
    </nav>

    <div class="lg:grid lg:grid-cols-[200px_1fr_220px] lg:gap-12">
      <!-- Sidebar: timeline -->
      <aside class="mb-10 hidden lg:block">
        <div class="sticky top-24">
          <p class="mb-4 text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-gray-500">
            Entradas
          </p>
          <ProjectTimeline
            entries={allEntries}
            projectSlug={projectSlug}
            currentEntrySlug={currentSlug}
          />
        </div>
      </aside>

      <!-- Main: article -->
      <article>
        <header class="mb-10">
          {
            category && (
              <p class="mb-2 font-mono text-xs uppercase tracking-wider text-blue-600 dark:text-blue-400">
                {category}
              </p>
            )
          }
          <h1 class="mb-4 text-3xl font-bold leading-tight text-gray-900 dark:text-gray-100">
            {title}
          </h1>
          <div class="flex items-center gap-4 text-sm text-gray-500 dark:text-gray-400">
            <time datetime={date.toISOString()}>{formatDate(date)}</time>
            <span>{readingTime} min de lectura</span>
          </div>
        </header>

        <div
          class="prose prose-gray max-w-none dark:prose-invert prose-headings:scroll-mt-20 prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline dark:prose-a:text-blue-400 prose-code:rounded prose-code:bg-gray-100 prose-code:px-1 prose-code:py-0.5 prose-code:font-mono prose-code:text-sm dark:prose-code:bg-gray-800 prose-pre:rounded-lg prose-pre:border prose-pre:border-gray-200 dark:prose-pre:border-gray-700"
        >
          <slot />
        </div>

        <!-- Entry navigation -->
        {
          (prev || next) && (
            <nav
              aria-label="Navegación entre entradas"
              class="mt-12 grid grid-cols-2 gap-4 border-t border-gray-200 pt-8 dark:border-gray-800"
            >
              {prev ? (
                <a href={`/projects/${projectSlug}/${getEntrySlug(prev)}`} class="group">
                  <p class="mb-1 text-xs text-gray-400 dark:text-gray-500">← Anterior</p>
                  <p class="text-sm font-medium text-gray-700 transition-colors group-hover:text-blue-600 dark:text-gray-300 dark:group-hover:text-blue-400">
                    {prev.data.title}
                  </p>
                </a>
              ) : (
                <div />
              )}
              {next && (
                <a
                  href={`/projects/${projectSlug}/${getEntrySlug(next)}`}
                  class="group text-right"
                >
                  <p class="mb-1 text-xs text-gray-400 dark:text-gray-500">Siguiente →</p>
                  <p class="text-sm font-medium text-gray-700 transition-colors group-hover:text-blue-600 dark:text-gray-300 dark:group-hover:text-blue-400">
                    {next.data.title}
                  </p>
                </a>
              )}
            </nav>
          )
        }
      </article>

      <!-- Right sidebar: TOC -->
      {
        headings.length > 0 && (
          <aside class="hidden lg:block">
            <div class="sticky top-24">
              <TableOfContents headings={headings} />
            </div>
          </aside>
        )
      }
    </div>
  </div>
</BaseLayout>
