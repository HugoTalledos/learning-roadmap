---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/blog/ArticleCard.astro';
import { getSortedPosts } from '../../utils/posts';

const posts = await getSortedPosts();
---

<BaseLayout
  title="Blog"
  description="Artículos técnicos sobre ingeniería de software, arquitectura, DevOps y experimentos."
>
  <div class="mx-auto max-w-content px-4 py-12">
    <header class="mb-10">
      <h1 class="mb-2 text-3xl font-bold text-gray-900 dark:text-gray-100">Blog</h1>
      <p class="text-sm text-gray-500 dark:text-gray-400">
        {posts.length} artículo{posts.length !== 1 ? 's' : ''}
      </p>
    </header>

    <div>
      {posts.map((post) => <ArticleCard post={post} />)}
    </div>
  </div>
</BaseLayout>
