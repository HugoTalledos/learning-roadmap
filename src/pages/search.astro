---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Buscar" description="Busca entre todos los artículos del blog.">
  <div class="mx-auto max-w-4xl px-4 py-12">
    <header class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100">Buscar</h1>
    </header>

    <div id="search"></div>

    <noscript>
      <p class="mt-4 text-sm text-gray-500 dark:text-gray-400">
        La búsqueda requiere JavaScript habilitado.
      </p>
    </noscript>
  </div>
</BaseLayout>

<!--
  Pagefind genera estos archivos en /dist/pagefind/ al ejecutar `npm run build`.
  En desarrollo, ejecuta `npm run build` al menos una vez para habilitar la búsqueda.
-->
<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
<script src="/pagefind/pagefind-ui.js" is:inline></script>
<script is:inline>
  window.addEventListener('DOMContentLoaded', () => {
    if (typeof PagefindUI === 'undefined') return;
    new PagefindUI({
      element: '#search',
      showSubResults: true,
      resetStyles: false,
      translations: {
        placeholder: 'Buscar artículos...',
        zero_results: 'Sin resultados para "[QUERY]"',
      },
    });
  });
</script>
