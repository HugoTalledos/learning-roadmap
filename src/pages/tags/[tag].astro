---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/blog/ArticleCard.astro';
import { getAllTags, getPostsByTag } from '../../utils/posts';

export async function getStaticPaths() {
  const tags = await getAllTags();
  return Promise.all(
    tags.map(async (tag) => ({
      params: { tag },
      props: { tag, posts: await getPostsByTag(tag) },
    }))
  );
}

const { tag, posts } = Astro.props;
---

<BaseLayout
  title={`#${tag}`}
  description={`Artículos etiquetados con ${tag}.`}
>
  <div class="mx-auto max-w-4xl px-4 py-12">
    <header class="mb-10">
      <p class="mb-1 font-mono text-xs text-gray-400 dark:text-gray-500">tag</p>
      <h1 class="mb-2 text-3xl font-bold text-gray-900 dark:text-gray-100">#{tag}</h1>
      <p class="text-sm text-gray-500 dark:text-gray-400">
        {posts.length} artículo{posts.length !== 1 ? 's' : ''}
      </p>
    </header>

    <div>
      {posts.map((post) => <ArticleCard post={post} />)}
    </div>
  </div>
</BaseLayout>
