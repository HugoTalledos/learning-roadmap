---
import type { CollectionEntry } from 'astro:content';

interface Props {
  prev?: CollectionEntry<'posts'>;
  next?: CollectionEntry<'posts'>;
}

const { prev, next } = Astro.props;
---

{
  (prev || next) && (
    <nav
      aria-label="Navegación entre artículos"
      class="mt-12 grid grid-cols-2 gap-4 border-t border-gray-200 pt-8 dark:border-gray-800"
    >
      {prev ? (
        <a href={`/blog/${prev.slug}`} class="group">
          <p class="mb-1 text-xs text-gray-400 dark:text-gray-500">← Anterior</p>
          <p class="text-sm font-medium text-gray-700 transition-colors group-hover:text-blue-600 dark:text-gray-300 dark:group-hover:text-blue-400">
            {prev.data.title}
          </p>
        </a>
      ) : (
        <div />
      )}

      {next && (
        <a href={`/blog/${next.slug}`} class="group text-right">
          <p class="mb-1 text-xs text-gray-400 dark:text-gray-500">Siguiente →</p>
          <p class="text-sm font-medium text-gray-700 transition-colors group-hover:text-blue-600 dark:text-gray-300 dark:group-hover:text-blue-400">
            {next.data.title}
          </p>
        </a>
      )}
    </nav>
  )
}
