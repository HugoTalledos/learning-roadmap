---
const year = new Date().getFullYear();
---

<footer class="mt-auto border-t border-gray-200 dark:border-gray-800">
  <div class="mx-auto flex max-w-content items-center justify-between px-4 py-6 text-sm text-gray-500 dark:text-gray-400">
    <span>© {year} Hugo Talledos</span>
    <div class="flex items-center gap-4">
      <a
        href="/rss.xml"
        class="font-mono transition-colors hover:text-gray-900 dark:hover:text-gray-100"
      >
        RSS
      </a>
      <a
        href="https://github.com/hugotalledos"
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors hover:text-gray-900 dark:hover:text-gray-100"
      >
        GitHub
      </a>
    </div>
  </div>
</footer>
