---
interface Props {
  tag: string;
  linked?: boolean;
}

const { tag, linked = false } = Astro.props;
const href = `/tags/${tag.toLowerCase()}`;

const baseClass =
  'font-mono text-xs px-2 py-1 rounded bg-gray-100 text-gray-600 transition-colors dark:bg-gray-800 dark:text-gray-400';
const hoverClass =
  'hover:bg-blue-100 hover:text-blue-700 dark:hover:bg-blue-900/30 dark:hover:text-blue-300';
---

{
  linked ? (
    <a href={href} class={`${baseClass} ${hoverClass}`}>
      #{tag}
    </a>
  ) : (
    <span class={baseClass}>#{tag}</span>
  )
}
