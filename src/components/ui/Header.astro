---
import ThemeToggle from './ThemeToggle.astro';

const navLinks = [
  // { href: '/blog', label: 'Blog' },
  { href: '/projects', label: 'Proyectos' },
  { href: '/about', label: 'Sobre mí' },
];

const current = Astro.url.pathname;
---

<header class="sticky top-0 z-10 border-b border-gray-200 bg-white/90 backdrop-blur-sm dark:border-gray-800 dark:bg-gray-950/90">
  <nav class="mx-auto flex h-14 max-w-content items-center justify-between px-4">
    <a
      href="/"
      class="font-mono font-semibold text-gray-900 transition-colors hover:text-blue-600 dark:text-gray-100 dark:hover:text-blue-400"
    >
      hugo.dev
    </a>

    <div class="flex items-center gap-1">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'rounded px-3 py-1.5 text-sm font-medium transition-colors',
              current.startsWith(link.href)
                ? 'text-blue-600 dark:text-blue-400'
                : 'text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-gray-100',
            ]}
          >
            {link.label}
          </a>
        ))
      }

      <ThemeToggle />
    </div>
  </nav>
</header>
